# ==============================================
# ScanBridge .gitignore
# ==============================================

# --- Python (Backend) ---
# Virtual environment
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Compiled Python files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Model AI (ukuran besar, diunduh otomatis saat runtime)
backend/models/*.pt
backend/models/*.onnx
backend/models/*.pth
backend/models/*.bin
backend/models/*.safetensors
backend/models/*.h5

# Data sementara hasil terjemahan
backend/temp/
backend/uploads/
backend/outputs/

# --- Flutter (Frontend) ---
# Flutter/Dart
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/flutter_*.log
frontend/.idea/
frontend/android/.gradle/
frontend/android/app/google-services.json
frontend/android/app/src/main/res/values/secrets.xml
frontend/android/key.properties
frontend/ios/.generated/
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Runner/GeneratedPluginRegistrant.*
frontend/macos/Flutter/GeneratedPluginRegistrant.swift
frontend/linux/flutter/
frontend/windows/flutter/

# Flutter Web
frontend/web/generated/

# --- General Development ---
# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- File Konfigurasi Pribadi ---
# Jangan commit file konfigurasi dengan kunci API atau secret
*.secret
secrets.yaml
config.local.yaml




CONTRIBUTING.md
